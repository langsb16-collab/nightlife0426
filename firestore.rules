// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: posts
// Fields:
//   - id: string (required)
//   - userId: string (required)
//   - category: string (required, enum)
//   - title: string (required)
//   - content: string (required)
//   - images: list of strings (optional)
//   - video: string (optional)
//   - lat: number (required)
//   - lng: number (required)
//   - address: string (required)
//   - likes: number (optional)
//   - dislikes: number (optional)
//   - createdAt: number (required)
//   - updatedAt: number (optional)
//
// Collection: rooms
// Fields:
//   - id: string (required)
//   - userA: string (required)
//   - userB: string (required)
//   - lastMessage: string (optional)
//   - updatedAt: number (required)
//
// Collection: rooms/{roomId}/messages
// Fields:
//   - id: string (required)
//   - roomId: string (required)
//   - senderId: string (required)
//   - message: string (required)
//   - type: string (required, enum)
//   - createdAt: number (required)
//
// Collection: reactions
// Fields:
//   - id: string (required)
//   - postId: string (required)
//   - userId: string (required)
//   - type: string (required, enum)
//   - createdAt: number (required)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['id', 'userId', 'category', 'title', 'content', 'lat', 'lng', 'address', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.category in ['jobs', 'realestate', 'market', 'drink', 'promo', 'food'];
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'roomId', 'senderId', 'message', 'type', 'createdAt']) &&
             data.message is string && data.message.size() > 0 && data.message.size() < 1000 &&
             data.type in ['text', 'image', 'voice'];
    }

    function isValidReaction(data) {
      return data.keys().hasAll(['id', 'postId', 'userId', 'type', 'createdAt']) &&
             data.type in ['like', 'dislike'];
    }

    // Posts
    match /posts/{postId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && isValidPost(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidPost(request.resource.data) && (request.resource.data.userId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes']));
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Chat Rooms
    match /rooms/{roomId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userA || request.auth.uid == resource.data.userB);
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.userA || request.auth.uid == request.resource.data.userB);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userA || request.auth.uid == resource.data.userB);
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.userA || request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.userB);
        allow create: if isAuthenticated() && isValidMessage(request.resource.data) && request.resource.data.senderId == request.auth.uid;
      }
    }

    // Reactions
    match /reactions/{reactionId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReaction(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
